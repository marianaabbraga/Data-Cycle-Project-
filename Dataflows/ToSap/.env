# ─────────────────────────────────────────────
# Configuration de connexion — export_to_csv.py
# Renommer ce fichier en ".env" à la racine du projet
# ─────────────────────────────────────────────

# Serveur SQL Server (nom ou IP)
# Exemple avec instance nommée : mon_pc\\SQLEXPRESS
# Exemple avec IP              : 192.168.1.10
DB_SERVER=.\STOCKSQLSERVER

# Nom de la base de données
DB_NAME=stockmarketdb2

# Authentification SQL Server
# Laisser vide pour utiliser l'authentification Windows (Trusted Connection)
DB_USER=
DB_PASSWORD=

# Dossier de sortie pour les CSV générés
OUTPUT_DIR=data/sap
