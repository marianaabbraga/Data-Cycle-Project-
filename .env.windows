# ============================================================
#  Windows local environment — no Docker
#  Copy/rename to .env or load with:
#    set /p < .env.windows   (cmd)
#    Get-Content .env.windows | ForEach-Object { ... }  (PowerShell)
#  Or just run start_windows.bat which sources this automatically.
# ============================================================

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# Data directory (absolute Windows path recommended)
DATA_DIR=./data

# SQL Server — Windows Authentication (no user/password needed).
# Change DB_SERVER to match your instance name, e.g.
#   localhost\SQLEXPRESS   or   .\STOCKSQLSERVER   or   just   localhost
DB_SERVER=localhost\STOCKSQLSERVER
DB_NAME=stockmarketdb2
DB_USER=
DB_PASSWORD=
DB_DRIVER={ODBC Driver 18 for SQL Server}

# AI analysis disabled in production -> overwatcher falls back to rule-based.
USE_AI_ANALYSIS=false

# (Leave the following unset/empty when AI is off. Uncomment and fill only if
# you re-enable USE_AI_ANALYSIS=true.)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OLLAMA_MODEL=qwen2.5:7b-instruct
# OLLAMA_SUPPORTS_TOOLS=true
# MARVIN_AGENT_MODEL=openai:gpt-4o-mini
# MARVIN_AGENT_RETRIES=8

# Schedule (default 06:00 UTC daily)
PIPELINE_CRON=0 6 * * *
